import React, { useState, useRef, useCallback, useEffect, memo } from 'react';
import { motion, AnimatePresence } from 'framer-motion';
import ControlPanel from '../ControlPanel/ControlPanel';
import InteractiveGrid from './InteractiveGrid/index';
import MatterCanvas from './MatterCanvas/index';
import Timebar, { ArrowUpIcon, ArrowDownIcon, RestartIcon, ChevronLeftIcon, ChevronRightIcon } from './Timebar';

// üåü Import Hooks ‡∏ó‡∏µ‡πà‡πÅ‡∏¢‡∏Å‡∏Å‡∏≤‡∏£‡∏ó‡∏≥‡∏á‡∏≤‡∏ô‡∏≠‡∏≠‡∏Å‡∏°‡∏≤
import { useSimulationHistory } from './hooks/useSimulationHistory';
import { useTimeManagement } from './hooks/useTimeManagement';
import { useWorkspaceState } from './hooks/useWorkspaceState';

const HoldableButton = memo(({ onAction, className, children, title, tabIndex }) => {
  const timerRef = useRef(null);
  const start = useCallback(() => {
    onAction();
    timerRef.current = setTimeout(() => {
      timerRef.current = setInterval(onAction, 80);
    }, 400);
  }, [onAction]);
  const stop = useCallback(() => {
    clearTimeout(timerRef.current);
    clearInterval(timerRef.current);
    timerRef.current = null;
  }, []);
  useEffect(() => () => stop(), [stop]);
  return <button tabIndex={tabIndex} onPointerDown={start} onPointerUp={stop} onPointerLeave={stop} className={className} title={title}>{children}</button>;
});

const SharedSlider = memo(({ label, value, min, max, step, onChange }) => (
  <div className="flex items-center gap-2 px-1">
    {label && <span className="text-xs font-semibold text-theme-muted">{label}</span>}
    <input type="range" min={min} max={max} step={step} value={value} onChange={onChange} className="w-20 h-1.5 bg-gray-300 dark:bg-gray-600 rounded-lg appearance-none cursor-pointer accent-[#FFB65A]" />
  </div>
));

const SimulationWorkspace = forwardRef(({ activeSim, isInteracting, onSaveControlState, onSavePhysicsState }, ref) => {
  const [simState, setSimState] = useState(activeSim?.data || null);
  const [camera, setCamera] = useState(activeSim?.physicsState?.camera || { offset: { x: 0, y: 0 }, zoom: 1 });
  const [vectorEditor, setVectorEditor] = useState(null);
  const [isToolbarOpen, setIsToolbarOpen] = useState(true);
  const [spawnToast, setSpawnToast] = useState(null);
  const [isClearModalOpen, setIsClearModalOpen] = useState(false);

  const [spawnConfig, setSpawnConfig] = useState({ shape: 'circle', size: 1, color: '#FFB65A', mass: 10, restitution: 0 });

  const matterCanvasRef = useRef(null);
  const controlPanelRef = useRef(null);

  const { pushToHistory, undoRef, redoRef } = useSimulationHistory(simState, setSimState, onSaveControlState);
  const { 
    isPlaying, setIsPlaying, hasStartedOnce, timeScale, setTimeScale, 
    displayTime, maxTime, timeStateRef, handleTogglePlay, handleRestart, handleSeek 
  } = useTimeManagement(simState, setSimState, onSaveControlState, matterCanvasRef, controlPanelRef);

  const {
    activeTool, setActiveTool, selectedObjectId, setSelectedObjectId,
    handleObjectSelect, handleToolChange, getSnappedPoint
  } = useWorkspaceState(simState, setSimState, matterCanvasRef);

  useEffect(() => {
    if (activeSim?.id) {
       setSimState(activeSim.data);
       if (matterCanvasRef.current) matterCanvasRef.current.resetSimulation();
    }
  }, [activeSim?.id]);

  useImperativeHandle(ref, () => ({
    getSnapshot: () => simState,
    resetView: () => setCamera({ offset: { x: 0, y: 0 }, zoom: 1 })
  }));

  const showToast = (message) => {
    setSpawnToast({ message, id: Date.now() });
    setTimeout(() => setSpawnToast(null), 3000);
  };

  const handleGridClick = useCallback((wx, wy, unitStep) => {
    if (activeTool === 'add') {
      const { nx, ny } = getSnappedPoint(wx, wy, unitStep);
      const newObj = {
        id: 'obj_' + Date.now(),
        isSpawned: true,
        shape: spawnConfig.shape,
        color: spawnConfig.color,
        size: spawnConfig.size,
        position: { x: nx, y: ny },
        values: { ...spawnConfig, height: ny }
      };
      pushToHistory(simState);
      if (controlPanelRef.current?.addObject) controlPanelRef.current.addObject(newObj);
    } else if (activeTool === 'erase') {
       // Logic for erasure...
    }
  }, [activeTool, simState, spawnConfig, getSnappedPoint, pushToHistory]);

  const handleGridPointerDown = useCallback((wx, wy, e, unitStep) => {
    if (activeTool === 'velocity' || activeTool === 'force') {
      const { nx, ny } = getSnappedPoint(wx, wy, unitStep);
      return matterCanvasRef.current?.startVectorDrag(nx, ny, activeTool, wx, wy) || false;
    }
    return false;
  }, [activeTool, getSnappedPoint]);

  const handleGridPointerMove = useCallback((wx, wy, e, unitStep) => {
    if (activeTool === 'velocity' || activeTool === 'force') {
      const { nx, ny } = getSnappedPoint(wx, wy, unitStep);
      matterCanvasRef.current?.moveVectorDrag(nx, ny);
    }
  }, [activeTool, getSnappedPoint]);

  const handleGridPointerUp = useCallback((wx, wy, e, unitStep) => {
    if (activeTool === 'velocity' || activeTool === 'force') {
      const { nx, ny } = getSnappedPoint(wx, wy, unitStep);
      const v = matterCanvasRef.current?.endVectorDrag(nx, ny);
      if (v) {
        const dx = v.currentX - v.startX;
        const dy = v.currentY - v.startY;
        const dist = Math.sqrt(dx*dx + dy*dy);
        if (dist > 0.1) {
           pushToHistory(simState);
           const magnitude = Math.round(dist * 5 * 10) / 10;
           const angle = Math.round(Math.atan2(dy, dx) * 180 / Math.PI);
           if (controlPanelRef.current?.updateObjectValues) {
             const obj = simState.objects.find(o => o.id === v.objId);
             const key = v.type === 'velocity' ? 'velocities' : 'forces';
             controlPanelRef.current.updateObjectValues(v.objId, { ...obj.values, [key]: [...(obj.values?.[key] || []), { magnitude, angle }] });
           }
        }
      }
    }
  }, [activeTool, simState, getSnappedPoint, pushToHistory]);

  const tools = [
    { id: 'cursor', title: '‡πÄ‡∏•‡∏∑‡∏≠‡∏Å (V)', icon: <path d="m3 3 7.07 16.97 2.51-7.39 7.39-2.51L3 3z"/> },
    { id: 'add', title: '‡πÄ‡∏û‡∏¥‡πà‡∏°‡∏ß‡∏±‡∏ï‡∏ñ‡∏∏ (A)', icon: <><circle cx="12" cy="12" r="10"/><path d="M8 12h8"/><path d="M12 8v8"/></> },
    { id: 'erase', title: '‡∏•‡∏ö‡∏ß‡∏±‡∏ï‡∏ñ‡∏∏ (E)', icon: <><path d="m7 21-4.3-4.3c-1-1-1-2.5 0-3.4l9.6-9.6c1-1 2.5-1 3.4 0l5.6 5.6c1 1 1 2.5 0 3.4L13 21"/><path d="M22 21H7"/><path d="m5 11 9 9"/></> },
    { id: 'velocity', title: '‡∏Ñ‡∏ß‡∏≤‡∏°‡πÄ‡∏£‡πá‡∏ß (B)', color: 'text-blue-500', icon: <><path d="M7 7h10v10"/><path d="M7 17 17 7"/></> },
    { id: 'force', title: '‡πÅ‡∏£‡∏á (F)', color: 'text-red-500', icon: <><path d="M7 7h10v10"/><path d="M7 17 17 7"/></> }
  ];

  return (
    <div className="flex-1 flex flex-col h-full w-full relative bg-[#1E1F22]">
      <div className="flex-1 flex min-h-0 px-6 pb-6 gap-4 pt-6">
        <div className="h-full z-20 w-[300px] shrink-0">
          <ControlPanel
            ref={controlPanelRef}
            initialState={simState || activeSim?.data}
            simulationType={activeSim?.simulationType || 'default'}
            isLocked={isPlaying}
            onUpdate={setSimState}
          />
        </div>

        <div className="flex-1 rounded-2xl overflow-hidden border border-theme-border bg-white dark:bg-[#2B2D31] relative shadow-sm">
          <div className="absolute top-4 left-4 z-50 flex gap-2 items-start pointer-events-none">
            <div className={`pointer-events-auto flex flex-col items-center bg-[#E5DDD4] dark:bg-[#313338] border border-theme-border rounded-[14px] shadow-md py-1 w-[42px]`}>
               {tools.map(tool => (
                 <button key={tool.id} onClick={() => handleToolChange(tool.id)} className={`w-8 h-8 flex items-center justify-center rounded-lg my-0.5 ${activeTool === tool.id ? 'bg-white dark:bg-[#1E1F22] text-theme-primary' : 'text-theme-secondary'}`}>
                   <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5">{tool.icon}</svg>
                 </button>
               ))}
            </div>
            {activeTool === 'add' && (
              <div className="bg-white dark:bg-[#313338] border border-theme-border rounded-[14px] shadow-lg p-2 flex items-center gap-3 pointer-events-auto">
                <select value={spawnConfig.shape} onChange={e => setSpawnConfig({...spawnConfig, shape: e.target.value})} className="bg-[#F2F3F5] dark:bg-[#1E1F22] text-sm rounded-lg px-2 py-1 outline-none">
                  <option value="circle">‡∏ß‡∏á‡∏Å‡∏•‡∏°</option>
                  <option value="rectangle">‡∏™‡∏µ‡πà‡πÄ‡∏´‡∏•‡∏µ‡πà‡∏¢‡∏°</option>
                  <option value="polygon-3">‡∏™‡∏≤‡∏°‡πÄ‡∏´‡∏•‡∏µ‡πà‡∏¢‡∏°</option>
                </select>
                <SharedSlider label="Size" min="0.5" max="4" step="0.1" value={spawnConfig.size} onChange={e => setSpawnConfig({...spawnConfig, size: parseFloat(e.target.value)})} />
              </div>
            )}
          </div>

          <InteractiveGrid
            initialCamera={camera}
            onCameraChange={setCamera}
            activeTool={activeTool}
            onGridClick={handleGridClick}
            onGridPointerDown={handleGridPointerDown}
            onGridPointerMove={handleGridPointerMove}
            onGridPointerUp={handleGridPointerUp}
          >
            {({ size, offset, zoom, unitStep }) => (
              <MatterCanvas
                ref={matterCanvasRef}
                size={size} offset={offset} zoom={zoom} unitStep={unitStep}
                simState={simState} onPhysicsChange={onSavePhysicsState}
                activeTool={activeTool} spawnConfig={spawnConfig}
                gridSnapping={!!simState?.gridSnapping}
                showCursorCoords={!!simState?.showCursorCoords}
                showResultantVector={!!simState?.showResultantVector}
                timeStateRef={timeStateRef}
                setIsPlaying={setIsPlaying}
                maxTime={maxTime}
              />
            )}
          </InteractiveGrid>

          <div className="absolute bottom-4 right-4 z-40">
            <Timebar
              isPlaying={isPlaying}
              displayTime={displayTime}
              maxTime={maxTime || 10}
              onTogglePlay={handleTogglePlay}
              onRestart={handleRestart}
              onSeek={handleSeek}
              timeScale={timeScale}
              onTimeScaleChange={setTimeScale}
            />
          </div>
        </div>
      </div>
    </div>
  );
});

export default memo(SimulationWorkspace);
∏≥‡∏•‡∏≠‡∏á‡∏à‡∏∞‡∏ñ‡∏π‡∏Å‡∏•‡∏ö‡∏ó‡∏¥‡πâ‡∏á<br/>‡πÅ‡∏•‡∏∞‡πÑ‡∏°‡πà‡∏™‡∏≤‡∏°‡∏≤‡∏£‡∏ñ‡∏Å‡∏π‡πâ‡∏Ñ‡∏∑‡∏ô‡πÑ‡∏î‡πâ
                </p>
                <div className="flex gap-3 w-full">
                  <button 
                    onClick={() => setIsClearModalOpen(false)} 
                    className="flex-1 px-4 py-2.5 bg-gray-100 hover:bg-gray-200 dark:bg-[#3F4147] dark:hover:bg-[#4d5057] text-gray-700 dark:text-gray-200 rounded-xl font-bold transition-colors cursor-pointer"
                  >
                    ‡∏¢‡∏Å‡πÄ‡∏•‡∏¥‡∏Å
                  </button>
                  <button 
                    onClick={handleClearAllConfirm} 
                    className="flex-1 px-4 py-2.5 bg-red-500 hover:bg-red-600 text-white rounded-xl font-bold transition-colors shadow-sm cursor-pointer"
                  >
                    ‡∏•‡∏ö‡∏ó‡∏¥‡πâ‡∏á
                  </button>
                </div>
              </div>
            </motion.div>
          </div>
        )}
      </AnimatePresence>
    </div>
  );
}